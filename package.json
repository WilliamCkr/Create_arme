{
  "name": "arena-object-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone external weapon asset pipeline for Arena Bloodline.",
  "scripts": {
    "check": "node src/cli/check-environment.mjs",
    "placeholder": "node src/cli/create-placeholder-frames.mjs",
    "atlas": "node src/cli/build-atlas.mjs",
    "validate": "node src/cli/validate-manifest.mjs",
    "export:arena": "node src/cli/export-arena-package.mjs",
    "forge:example": "npm run check && npm run placeholder && npm run atlas && npm run validate",
    "ui": "node src/ui/server.mjs",
    "ui:server": "node src/ui/server.mjs",
    "ui:dev": "node --watch src/ui/server.mjs"
  },
  "dependencies": {
    "sharp": "^0.34.3",
    "three": "^0.184.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
